    {
      "id": "d4e5f6a7-0003-0003-0003-000000000003",
      "name": "Code: Extraer items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300],
      "parameters": {
        "jsCode": "const items = $json.data?.boards?.[0]?.items_page?.items || [];\nreturn items.map(item => {\n  const cols = {};\n  item.column_values.forEach(c => { cols[c.id] = c.text; });\n  return {\n    json: {\n      monday_item_id: item.id,\n      titulo: item.name,\n      tipo: (cols.color_mm4p82jm || '').toLowerCase(),\n      fecha_envio: cols.date_mm4p3am8\n    }\n  };\n});"
      }
    },
    {
      "id": "d4e5f6a7-0004-0004-0004-000000000004",
      "name": "Loop: Por item",
      "type": "n8n-nodes-base.splitInBatches",
