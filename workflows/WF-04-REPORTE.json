        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ query: `query { boards(ids: [18419499542]) { items_page(limit: 100, query_params: { rules: [{ column_id: \"color_mm4p7mve\", compare_value: [\"ENVIADO\",\"ENVIANDO\"], operator: any_of }] }) { items { id name column_values { id text } } } } }` }) }}"
      },
