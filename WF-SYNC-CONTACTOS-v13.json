    {
      "parameters": {},
      "id": "94bae7de-be1a-4d7d-8921-8692741a718c",
      "name": "Merge Combinar Conteos",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [20784, 2880]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst ctx   = $('Code Preparar Contexto').first().json;\n\nconst totales      = items.map(i => Number(i.json.Total ?? 0));\nconst deltaTotal   = Math.min(...totales);\nconst mailjetTotal = Math.max(...totales);\n\nconst hayNuevos      = mailjetTotal > ctx.pg_count;\nconst tsEfectivo     = hayNuevos ? 0 : ctx.last_sync_unix;\nconst totalAProcesar = hayNuevos ? mailjetTotal : deltaTotal;\nconst hayCambios     = totalAProcesar > 0;\n\nreturn [{\n  json: {\n    ts_efectivo:      tsEfectivo,\n    hay_cambios:      hayCambios,\n    total_a_procesar: totalAProcesar,\n    hay_nuevos:       hayNuevos,\n    delta_total:      deltaTotal,\n    mailjet_total:    mailjetTotal,\n    pg_count:         ctx.pg_count,\n    ts_inicio:        ctx.ts_inicio,\n    fecha_inicio:     ctx.fecha_inicio\n  }\n}];"
      },
      "id": "8f368742-aa69-4474-bf30-7a00005ae1b0",
      "name": "Code Decidir ts_efectivo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [21008, 2880]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 1 },
          "conditions": [
            {
              "id": "filter-sync-01",
              "leftValue": "={{ $json.total_a_procesar }}",
              "rightValue": 0,
              "operator": { "type": "number", "operation": "gt" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "da020347-e898-416b-ba3f-f9b45308e196",
      "name": "[Filter] ¿Hay cambios?",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [21232, 2880]
    },
    {
      "parameters": {
        "jsCode": "const total = Number($json.total_a_procesar ?? 0);\nconst limit = 1000;\nconst pages = Math.max(1, Math.ceil(total / limit));\nconst ts_efectivo = $('Code Decidir ts_efectivo').first().json.ts_efectivo;\nreturn Array.from({ length: pages }, (_, i) => ({\n  json: { offset: i * limit, pageLimit: limit, last_sync_unix: ts_efectivo }\n}));"
      },
