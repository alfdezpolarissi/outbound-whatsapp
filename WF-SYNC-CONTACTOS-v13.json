    {
      "parameters": {
        "jsCode": "// v13: Lee IDs del delta desde staticData (guardados en Collapse → Fase 2).\n// Emite {id_mailjet, listas_mailjet} — el upsert completo ya se hizo en Fase 1.\nconst sd = $getWorkflowStaticData('global');\nconst deltaIds = new Set((sd.delta_ids || []).map(String));\n\nconst listasMapa = {};\nfor (const item of $input.all()) {\n  for (const row of (item.json.Data || [])) {\n    const cid = String(row.ContactID);\n    if (!deltaIds.has(cid)) continue;\n    const lista = row.ContactsListName || String(row.ListID);\n    if (!listasMapa[cid]) listasMapa[cid] = new Set();\n    listasMapa[cid].add(lista);\n  }\n}\n\nreturn [...deltaIds].map(cid => ({\n  json: {\n    id_mailjet:     Number(cid),\n    listas_mailjet: listasMapa[cid] ? [...listasMapa[cid]].join(',') : ''\n  }\n}));"
      },
      "id": "b777318e-77bb-424e-8491-edc8f14c7bf2",
      "name": "Code Consolidar Listas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
