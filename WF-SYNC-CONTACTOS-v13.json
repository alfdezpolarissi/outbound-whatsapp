    {
      "parameters": {
        "jsCode": "// v13: Lee IDs desde staticData y emite {id_mailjet, listas_mailjet}.\n// El upsert completo ya se hizo en Fase 1.\nconst sd = $getWorkflowStaticData('global');\nconst deltaIds = $('Code IDs Delta para Listas').all();\n\nreturn $input.all().map((item, idx) => {\n  const id_mailjet = deltaIds[idx]?.json.idmailjet;\n  const listas_mailjet = (item.json.Data ?? [])\n    .map(l => l.Name || String(l.ListID))\n    .join(',');\n  return { json: { id_mailjet: Number(id_mailjet), listas_mailjet } };\n});"
      },
