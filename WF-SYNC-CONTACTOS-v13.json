      "parameters": {
        "jsCode": "const tsInicio    = $('Code Preparar Contexto').first().json.ts_inicio;\nconst fechaInicio = $('Code Preparar Contexto').first().json.fecha_inicio;\nconst contactosProcesados = $('Postgres UPDATE listas_mailjet').all().length;\nconst fechaFin   = new Date().toISOString();\nconst duracionMs = Date.now() - tsInicio;\n\nreturn [{\n  json: {\n    fecha_inicio:         fechaInicio,\n    fecha_fin:            fechaFin,\n    duracion_ms:          duracionMs,\n    contactos_procesados: contactosProcesados,\n    estado:               'ok'\n  }\n}];"
